@model Dal.Dragones.Factura
@using System.Security.Claims
@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<html lang="es">
<head>
    <style>
        .nav-item a {
            text-decoration: none; /* Quitar subrayado */
            color: inherit; /* Heredar el color del texto */
            display: inline-block; /* Hacerlo un bloque en línea para aplicar padding correctamente */
            cursor: pointer; /* Cambiar el cursor a puntero */
            font-size: 27px;
        }
    </style>
</head>
<body>
    <div class="content-page-container full-reset custom-scroll-containers">
        <nav class="navbar-user-top full-reset">
            <ul class="list-unstyled full-reset">
                <figure>
                    <img src="~/assets/img/user01.png" alt="user-picture" class="img-responsive img-circle center-box">
                </figure>
                <li class="user-info" style="color:#fff; cursor:default;">
                    @if (User.Identity.IsAuthenticated)
                    {
                    <li class="user-info">
                        <div class="user-details">
                            <span data-placement="bottom" title="Usuario">Bienvenido, @User.FindFirst(ClaimTypes.Role)?.Value @User.Identity.Name</span>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a class="" asp-area="" asp-controller="Login" asp-action="Salir">
                            <i class="zmdi zmdi-power"></i>
                        </a>
                    </li>
                    }

                </li>
                <li class="tooltips-general btn-help" data-placement="bottom" title="Ayuda">
                    <i class="zmdi zmdi-help-outline zmdi-hc-fw"></i>
                </li>
                <li class="mobile-menu-button visible-xs" style="float: left !important;">
                    <i class="zmdi zmdi-menu"></i>
                </li>
                <li class="desktop-menu-button hidden-xs" style="float: left !important;">
                    <i class="zmdi zmdi-swap"></i>
                </li>
            </ul>
        </nav>

        <div class="container">
            <div class="page-header">
                <h1 class="all-tittles">Sistema Restaurante Los Dragones <small>Detalles de factura</small></h1>
            </div>
        </div>
        <div class="container-fluid" style="margin: 50px 0;">
            <div class="row">
                <div class="col-xs-12 col-sm-4 col-md-3">
                    <img src="~/assets/img/user01.png" alt="user" class="img-responsive center-box" style="max-width: 110px;">
                </div>
                <div class="col-xs-12 col-sm-8 col-md-8 text-justify lead">
                    Bienvenido a la sección de detalles de factura. En esta seccion podras visualizar los datos de una factura en especifico.
                </div>
            </div>
        </div>

        <div class="container-fluid">
            <div class="row">
                <div class="col-xs-12 lead">
                    <ol class="breadcrumb">
                        <li class="active">Detalle de Factura</li>
                        <li><a asp-controller="Factura" asp-action="Index">Facturas</a></li>
                    </ol>
                </div>
            </div>
        </div>
        <div class="container-flat-form">
            <div class="title-flat-form title-flat-blue">Detalles de factura</div>
            <div class="container-fluid">
                <h2 class="all-tittles">@Html.DisplayNameFor(model => model.Fecha) : <small>@Html.DisplayFor(model => model.Fecha)</small></h2>
                <h2 class="all-tittles">Nombre del Cliente : <small>@Html.DisplayFor(model => model.NombreCliente)</small></h2>
                <h2 class="all-tittles">@Html.DisplayNameFor(model => model.Responsable) : <small>@Html.DisplayFor(model => model.Responsable)</small></h2>
                <h2 class="all-tittles">Productos:</h2>
               
                <div class="container mt-5">
                    <table class="table table-secondary table-bordered table-hover">
                        <thead class="thead-dark">
                            <tr>
                                <th>Nombre</th>
                                <th>Precio</th>
                                <th>Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detalle in Model.Pedidos.Detalles)
                            {
                                <tr data-id="@detalle.Id" data-categoria="@detalle.Categoria" data-lista-comida="@detalle.ListaComida">
                                    <td>@detalle.Nombre</td>
                                    <td>@detalle.Precio</td>
                                    <td>@detalle.Cantidad</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <h2 class="all-tittles">@Html.DisplayNameFor(model => model.Subtotal) : <small>@Html.DisplayFor(model => model.Subtotal)</small></h2>
                <h2 class="all-tittles">@Html.DisplayNameFor(model => model.Iva) : <small>@Html.DisplayFor(model => model.Iva)%</small></h2>
                <h2 class="all-tittles">@Html.DisplayNameFor(model => model.TotalPagar) : <small>@Html.DisplayFor(model => model.TotalPagar)</small></h2>
                <h2 class="all-tittles">@Html.DisplayNameFor(model => model.Observaciones) : <small>@Html.DisplayFor(model => model.Observaciones)</small></h2>
                <h2 class="all-tittles">@Html.DisplayNameFor(model => model.MetodoPago) : <small>@Html.DisplayFor(model => model.MetodoPago)</small></h2>
                <h2 class="all-tittles">Estado del pedido : <small>@Html.DisplayFor(model => model.Pedidos.Estado)</small></h2>

                <!-- Botón para abrir el modal -->
                <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#creditNoteModal">
                    Aplicar Nota de Crédito
                </button>

                <!-- Modal -->
                <div class="modal fade" id="creditNoteModal" tabindex="-1" role="dialog" aria-labelledby="creditNoteModalLabel" aria-hidden="true">
                    <div class="modal-dialog" role="document">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="creditNoteModalLabel">Aplicar Nota de Crédito</h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <form id="creditNoteForm">
                                    <div class="mb-3">
                                        <label for="creditNoteAmount" class="form-label">Monto de la Nota de Crédito</label>
                                        <input type="number" class="form-control" id="creditNoteAmount" required>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Aplicar</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <a asp-action="Index">
                    <button class="btn btn-primary">
                        Volver a facturas
                    </button>
                </a>
                <a class="btn btn-primary" href="@Url.Action("DownloadPDF", "Factura", new { id = Model.id })">Descargar PDF</a>
            </div>
        </div>
    </div>
    </div>
    
    <script>
        $(document).ready(function () {
            $('#tabla').DataTable({
                language: {
                    processing: "Procesando...",
                    search: "Buscar:",
                    lengthMenu: "Mostrar MENU elementos",
                    info: "Mostrando del START al END de un total de TOTAL elementos",
                    infoEmpty: "Mostrando 0 elementos",
                    infoFiltered: "(filtrado de un total de MAX elementos)",
                    infoPostFix: "",
                    loadingRecords: "Cargando...",
                    zeroRecords: "No se encontraron registros coincidentes",
                    emptyTable: "No hay datos disponibles en la tabla",
                    paginate: {
                        first: "Primero",
                        previous: "Anterior",
                        next: "Siguiente",
                        last: "Último"
                    },
                    aria: {
                        sortAscending: ": activar para ordenar la columna de manera ascendente",
                        sortDescending: ": activar para ordenar la columna de manera descendente"
                    }
                }
            });
        });


    </script>

    <script>
        document.getElementById('creditNoteForm').addEventListener('submit', function (event) {
            event.preventDefault();

            const facturaId = @Model.id;
            const creditNoteAmount = parseFloat(document.getElementById('creditNoteAmount').value);

            $.ajax({
                url: '@Url.Action("AplicarNotaDeCredito", "Factura")',
                type: 'POST',
                data: {
                    facturaId: facturaId,
                    monto: creditNoteAmount
                },
                success: function (response) {
                    if (response.success) {
                        // Actualizar el total de la factura en la vista
                        $('#totalFactura').text(response.nuevoTotal);
                        // Cerrar el modal
                        $('#creditNoteModal').modal('hide');
                    } else {
                        alert('Error al aplicar la nota de crédito.');
                    }
                },
                error: function () {
                    alert('Error en la solicitud.');
                }
            });
        });
    </script>
</body>
</html>