<!DOCTYPE html>
<html lang="en">
<head>
    <title>Inicio</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="Shortcut Icon" type="image/x-icon" href="~assets/icons/book.ico" />
    <script src="~js/sweet-alert.min.js"></script>
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

    <link rel="stylesheet" href="~/css/">
    <link rel="stylesheet" href="~/css/material-design-iconic-font.min.css">
    <link rel="stylesheet" href="~/css/normalize.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/jquery.mCustomScrollbar.css">
    <link rel="stylesheet" href="~/css/style.css">
    <script src="//ajax.googleapis.com/ajax/libs/jquery/1.11.2/jquery.min.js"></script>
    <script>window.jQuery || document.write('<script src="js/jquery-1.11.2.min.js"><\/script>')</script>
    <script src="~/js/modernizr.js"></script>
    <script src="~/js/bootstrap.min.js"></script>
    <script src="~/js/jquery.mCustomScrollbar.concat.min.js"></script>
    <script src="~/js/main.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.5/css/dataTables.dataTables.css" />
    <script src="https://cdn.datatables.net/plug-ins/1.11.7/i18n/Spanish.json"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
</head>
<body>
    <div class="navbar-lateral full-reset">
        <div class="visible-xs font-movile-menu mobile-menu-button"></div>
        <div class="full-reset container-menu-movile nav-lateral-scroll">
            <div class="logo full-reset all-tittles">
                <i class="visible-xs zmdi zmdi-close pull-left mobile-menu-button" style="line-height: 55px; cursor: pointer; padding: 0 10px; margin-left: 7px;"></i>
                Sistema Restaurante Los Dragones
            </div>
            <div class="nav-lateral-divider full-reset"></div>
            <div class="full-reset" style="padding: 10px 0; color:#fff;">
                <figure>
                    <img src="~/assets/img/Logo_LosDragones.png" alt="Los Dragones" class="img-responsive center-box" style="width:55%;">
                </figure>
                <p class="text-center" style="padding-top: 15px;">Sistema Restaurante Los Dragones</p>
            </div>
            <div class="nav-lateral-divider full-reset"></div>
            <div class="full-reset nav-lateral-list-menu">
                <ul class="list-unstyled">
                    <li><a asp-controller="Home" asp-action="home"><i class="zmdi zmdi-home zmdi-hc-fw"></i>&nbsp;&nbsp; Inicio</a></li>
                    @if (User.IsInRole("Administrador"))
                    {
                        <li>
                            <div class="dropdown-menu-button"><i class="zmdi zmdi-case zmdi-hc-fw"></i>&nbsp;&nbsp; Administración <i class="zmdi zmdi-chevron-down pull-right zmdi-hc-fw icon-sub-menu"></i></div>
                            <ul class="list-unstyled">
                                <li>
                                    <div class="dropdown-menu-button"><i class="zmdi zmdi-account-add zmdi-hc-fw"></i>&nbsp;&nbsp; Registro de usuarios <i class="zmdi zmdi-chevron-down pull-right zmdi-hc-fw icon-sub-menu"></i></div>
                                    <ul class="list-unstyled">
                                        <li><a asp-controller="Usuario" asp-action="Create"><i class="zmdi zmdi-face zmdi-hc-fw"></i>&nbsp;&nbsp; Nuevo Usuario</a></li>
                                        <li><a asp-controller="Usuario" asp-action="Index"><i class="zmdi zmdi-bookmark-outline zmdi-hc-fw"></i>&nbsp;&nbsp; Listado Usuarios</a></li>
                                        <li><a asp-controller="Rol" asp-action="Index"><i class="zmdi zmdi-balance zmdi-hc-fw"></i>&nbsp;&nbsp; Roles</a></li>
                                    </ul>
                                </li>
                                <li><a asp-controller="Reporte" asp-action="Index"> <i class="zmdi zmdi-assignment-o"></i> &nbsp;&nbsp; Reportes </a></li>
                                <li>
                                    <a asp-controller="Plato" asp-action="Index"><i class="zmdi zmdi-balance-wallet"></i>&nbsp;&nbsp; Ver Platos</a>
                                </li>
                            </ul>
                        </li>
                    }
                    <li>
                        <div class="dropdown-menu-button"><i class="zmdi zmdi-pizza zmdi-hc-fw"></i>&nbsp;&nbsp; Ordenes <i class="zmdi zmdi-chevron-down pull-right zmdi-hc-fw icon-sub-menu"></i></div>
                        <ul class="list-unstyled">
                            <li><a asp-controller="Pedido" asp-action="Index"><i class="zmdi zmdi-cutlery"></i>&nbsp;&nbsp; Ver Pedidos</a></li>
                            <li><a asp-controller="Pedido" asp-action="Mesero"><i class="zmdi zmdi-cocktail"></i>&nbsp;&nbsp; Vista Meseros</a></li>
                            <li><a asp-controller="Pedido" asp-action="Cocina"><i class="zmdi zmdi-collection-text"></i>&nbsp;&nbsp; Vista Cocina</a></li>
                        </ul>
                    </li>
                    <li>
                        <a asp-controller="Factura" asp-action="Index"><i class="zmdi zmdi-balance-wallet"></i>&nbsp;&nbsp; Ver facturas</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    @RenderBody()
</body>


<script>
    var logoutUrl = '@Url.Action("Salir", "Login")';
    var indexUrl = '@Url.Action("Index", "Login")';
</script>

<script src="https://cdn.datatables.net/2.0.5/js/dataTables.js"></script>


</html>
