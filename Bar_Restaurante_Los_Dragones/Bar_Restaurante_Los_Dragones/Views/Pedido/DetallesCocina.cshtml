@model Dal.Dragones.Pedido

@{
    ViewBag.Title = "Detalles del Pedido";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Estilos -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css">
    <style>
        .container-table {
            max-width: 90%;
            margin: auto;
        }

        .nav-item a {
            text-decoration: none;
            color: inherit;
            display: inline-block;
            cursor: pointer;
            font-size: 27px;
        }

        .btn-link {
            color: #007bff;
            text-decoration: none;
            background-color: transparent;
            border: none;
            padding: 0;
            cursor: pointer;
        }

            .btn-link:hover {
                text-decoration: underline;
            }
    </style>
</head>
<body>
    <div class="content-page-container full-reset custom-scroll-containers">
        <!-- Navbar -->
        <nav class="navbar-user-top full-reset">
            <ul class="list-unstyled full-reset">
                <figure>
                    <img src="~/assets/img/user01.png" alt="user-picture" class="img-responsive img-circle center-box">
                </figure>
                <li class="user-info" style="color:#fff; cursor:default;">
                    @if (User.Identity.IsAuthenticated)
                    {
                    <li class="user-info">
                        <div class="user-details">
                            <span data-placement="bottom" title="Usuario">Bienvenido, @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value @User.Identity.Name</span>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a href="#" id="logout-button" class="exit-system-button">
                            <i class="zmdi zmdi-power"></i>
                        </a>
                    </li>
                    }
                </li>
                <li class="tooltips-general btn-help" data-placement="bottom" title="Ayuda">
                    <i class="zmdi zmdi-help-outline zmdi-hc-fw"></i>
                </li>
                <li class="mobile-menu-button visible-xs" style="float: left !important;">
                    <i class="zmdi zmdi-menu"></i>
                </li>
                <li class="desktop-menu-button hidden-xs" style="float: left !important;">
                    <i class="zmdi zmdi-swap"></i>
                </li>
            </ul>
        </nav>

        <!-- Contenido principal -->
        <div class="container">
            <div class="page-header">
                <h1 class="all-tittles">Sistema Restaurante Los Dragones <small>Detalles del Pedido</small></h1>
            </div>
        </div>

        <div class="container-fluid" style="margin: 50px 0;">
            <div class="row">
                <div class="col-xs-12 col-sm-4 col-md-3">
                    <img src="~/assets/img/user01.png" alt="user" class="img-responsive center-box" style="max-width: 110px;">
                </div>
                <div class="col-xs-12 col-sm-8 col-md-8 text-justify lead">
                    En esta sección puedes ver los detalles específicos del pedido realizado en el sistema.
                </div>
            </div>
        </div>

        <div class="container-fluid">
            <div class="row">
                <div class="col-xs-12 lead">
                    <ol class="breadcrumb">
                        <li><a asp-controller="Pedido" asp-action="Cocina">Listado de Cocina</a></li>
                        <li class="active">Detalles del Pedido</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Detalles del Pedido -->
        <div class="container-table">
            <h2>Detalles del Pedido</h2>
            <p>Mesa: @Model.Mesa.NumMesa</p>
            <p>Fecha: @Model.Fecha</p>
            <p>Total: @Model.Total</p>
            <p>Estado: @Model.Estado</p>

            <h3>Platos</h3>
            <form asp-action="CambiarDisponibilidad" method="post">
                <input type="hidden" name="idPedido" value="@Model.Id" /> <!-- Campo oculto para idPedido -->
                <table class="table table-bordered table-hover" id="detalles-table">
                    <thead class="thead-dark">
                        <tr>
                            <th>
                                <input type="checkbox" id="seleccionarTodos" />
                            </th>
                            <th>Nombre</th>
                            <th>Precio</th>
                            <th>Cantidad</th>
                            <th>Listo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detalle in Model.Detalles)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" class="detalle-checkbox" name="detallesSeleccionados" value="@detalle.Id"
                                    @(detalle.Categoria == "Comida" ? "" : "disabled") />
                                </td>
                                <td>@detalle.Nombre</td>
                                <td>@detalle.Precio</td>
                                <td>@detalle.Cantidad</td>
                                <td>
                                    @if (detalle.ListaComida)
                                    {
                                        <span class="text-success">&#x2714;</span> <!-- Check mark -->
                                    }
                                    else
                                    {
                                        <span class="text-warning">&#x26A0;</span> <!-- Warning icon -->
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <button type="submit" class="btn btn-success">Marcar Seleccionados como Listo</button>
            </form>

            <form asp-action="FinalizarPedido" method="post">
                <input type="hidden" name="idPedido" value="@Model.Id" />
                <button type="submit" class="btn btn-success">Finalizar Orden</button>
            </form>

            <a asp-action="Cocina">Volver a Cocina</a>
        </div>

    </div>

    <!-- Configuración adicional de DataTables, si es necesario -->
    <script>
        $(document).ready(function () {
            // Configuración básica de DataTables
            $('#detalles-table').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.10.16/i18n/Spanish.json"
                }
            });

            // Manejar el clic en el checkbox de "Seleccionar Todos"
            $('#seleccionarTodos').click(function () {
                $('.detalle-checkbox').each(function () {
                    var isChecked = $(this).is(':enabled');
                    if (isChecked) {
                        $(this).prop('checked', $('#seleccionarTodos').is(':checked'));
                    }
                });
            });
        });
    </script>
</body>
</html>
