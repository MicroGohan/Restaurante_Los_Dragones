@model Dal.Dragones.Pedido

@{
    ViewBag.Title = "Crear Pedido";
}
@using System.Security.Claims
@using Newtonsoft.Json


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        .container-table {
            max-width: 90%;
            margin: auto;
            padding-bottom: 70px; /* Asegura suficiente espacio al final */
        }

        .nav-item a {
            text-decoration: none;
            color: inherit;
            display: inline-block;
            cursor: pointer;
            font-size: 27px;
        }

        .mesa-boton {
            display: inline-block;
            margin: 5px;
            padding: 10px 20px;
            border: 1px solid #ccc;
            cursor: pointer;
            border-radius: 8px;
            font-size: 16px;
            transition: transform 0.3s, background-color 0.3s;
        }

            .mesa-boton:hover {
                transform: scale(1.05);
            }

        .mesa-disponible {
            background-color: #90ee90; /* Verde claro */
        }

        .mesa-ocupada {
            background-color: #f08080; /* Rojo claro */
            cursor: not-allowed;
        }

        .mesa-seleccionada {
            border: 2px solid #0000ff; /* Azul */
        }

        .card {
            border: 1px solid #ddd;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .card-body {
            padding: 15px;
        }

        .card-title {
            font-size: 1.25rem;
            margin-bottom: 0.75rem;
        }

        .card-text {
            margin-bottom: 1.25rem;
        }

        .card {
            margin-bottom: 20px;
            max-width: 250px; /* Tamaño máximo de la tarjeta */
            border: 1px solid #ddd;
            border-radius: 5px;
        }

        .card-img-top {
            width: 100%;
            height: 150px; /* Altura fija para las imágenes */
            object-fit: cover; /* Asegura que la imagen cubra el área sin distorsionar */
        }

        .btn-success {
            font-size: 16px; /* Aumenta el tamaño del texto del botón */
            padding: 10px 20px; /* Aumenta el padding del botón */
            margin-top: 05px; /* Agrega un margen superior para separarlo del contenido */
        }

        .button-container {
            display: flex;
            justify-content: center; /* Centra el contenido horizontalmente */
        }

        .scrollable-container {
            max-height: 350px; /* Define una altura máxima fija */
            overflow-y: auto; /* Solo habilita el scroll vertical */
        }
    </style>
</head>
<body>
    <div class="content-page-container full-reset custom-scroll-containers">
        <!-- Navbar -->
        <nav class="navbar-user-top full-reset">
            <ul class="list-unstyled full-reset">
                <figure>
                    <img src="~/assets/img/user01.png" alt="user-picture" class="img-responsive img-circle center-box">
                </figure>
                <li class="user-info" style="color:#fff; cursor:default;">
                    @if (User.Identity.IsAuthenticated)
                    {
                    <li class="user-info">
                        <div class="user-details">
                            <span data-placement="bottom" title="Usuario">Bienvenido, @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value @User.Identity.Name</span>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a class="" asp-area="" asp-controller="Login" asp-action="Salir">
                            <i class="zmdi zmdi-power"></i>
                        </a>
                    </li>
                    }
                </li>
                <li class="tooltips-general btn-help" data-placement="bottom" title="Ayuda">
                    <i class="zmdi zmdi-help-outline zmdi-hc-fw"></i>
                </li>
                <li class="mobile-menu-button visible-xs" style="float: left !important;">
                    <i class="zmdi zmdi-menu"></i>
                </li>
                <li class="desktop-menu-button hidden-xs" style="float: left !important;">
                    <i class="zmdi zmdi-swap"></i>
                </li>
            </ul>
        </nav>

        <!-- Contenido principal -->
        <div class="container">
            <div class="page-header">
                <h1 class="all-tittles">Sistema Restaurante Los Dragones <small>Crear Pedido</small></h1>
            </div>
        </div>

        <div class="container-fluid" style="margin: 50px 0;">
            <div class="row">
                <div class="col-xs-12 col-sm-4 col-md-3">
                    <img src="~/assets/img/user01.png" alt="user" class="img-responsive center-box" style="max-width: 110px;">
                </div>
                <div class="col-xs-12 col-sm-8 col-md-8 text-justify lead">
                    En esta sección puedes crear un nuevo pedido para el restaurante.
                </div>
            </div>
        </div>

        <div class="container-fluid">
            <div class="row">
                <div class="col-xs-12 lead">
                    <ol class="breadcrumb">
                        <li><a asp-controller="Pedido" asp-action="Mesero">Mesero</a></li>
                        <li class="active">Crear Pedido</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Formulario de creación de pedido -->
        <div class="container-table">
            <h2>Crear Pedido</h2>

            <form asp-action="CrearPedido" method="post">
                <div>
                    <label>Mesa</label>
                    <div id="mesasContainer">
                        @foreach (var mesa in ViewBag.Mesas)
                        {
                            var estadoClase = mesa.Estado == "OCUPADA" ? "mesa-ocupada" : "mesa-disponible";
                            <button type="button" class="mesa-boton @estadoClase" data-id="@mesa.Id" data-estado="@mesa.Estado">
                                @mesa.NumMesa - @mesa.Estado
                                @if (mesa.Estado == "OCUPADA" && mesa.Pedidos != null && mesa.Pedidos.Count > 0)
                                {
                                    var pedidoActivo = GetPedidoActivo(mesa.Pedidos);

                                    @if (pedidoActivo != null && pedidoActivo.Fecha != null)
                                    {
                                        <span class="pedido-tiempo">
                                            Hace @GetTiempoTranscurrido(pedidoActivo.Fecha)
                                        </span>
                                    }
                                }
                            </button>
                        }

                        @functions {
                            public string GetTiempoTranscurrido(DateTime fechaPedido)
                            {
                                var tiempoTranscurrido = DateTime.Now - fechaPedido;

                                if (tiempoTranscurrido.TotalMinutes < 60)
                                {
                                    return $"{tiempoTranscurrido.TotalMinutes.ToString("0")} minutos";
                                }
                                else
                                {
                                    var horas = (int)tiempoTranscurrido.TotalHours;
                                    var minutosRestantes = tiempoTranscurrido.Minutes;

                                    if (minutosRestantes == 0)
                                    {
                                        return $"{horas} horas";
                                    }
                                    else
                                    {
                                        return $"{horas} horas y {minutosRestantes} minutos";
                                    }
                                }
                            }

                            public Dal.Dragones.Pedido GetPedidoActivo(ICollection<Dal.Dragones.Pedido> pedidos)
                            {
                                var estadosOcupados = new List<string> { "PENDIENTE", "LISTO PARA PREPARAR", "ORDEN LISTA" };

                                foreach (var pedido in pedidos)
                                {
                                    if (estadosOcupados.Contains(pedido.Estado))
                                    {
                                        return pedido;
                                    }
                                }
                                return null;
                            }
                        }

                    </div>
                    <input type="hidden" id="IdMesa" name="IdMesa" />

                </div>

                <div>
                    <label>Observación</label>
                    <input type="text" name="Observacion" class="form-control" />
                </div>

                <div>
                    <label>Buscar Plato</label>
                    <input type="text" id="searchPlato" class="form-control" placeholder="Buscar plato..." />
                </div>

                <div>
                    <label>Seleccionar Plato</label>
                    <div id="platosContainer" class="scrollable-container">
                        <!-- Contenido con scroll -->
                    </div>
                </div>



                <br />
                <br />
                <div>
                    <label>Platos Seleccionados y Cantidades</label>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Plato</th>
                                <th>Cantidad</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="platosSeleccionados">
                            <!-- Aquí se añadirán los platos seleccionados -->
                        </tbody>
                    </table>
                </div>

                <div>
                    <label>Total:</label>
                    <span id="totalPedido">0</span>
                    <input type="hidden" id="Total" name="Total" value="0" />
                </div>

                <div class="button-container">
                    <button type="submit" class="btn btn-success">Crear Pedido</button>
                </div>
            </form>
        </div>

        <!-- Modal de aviso de productos -->
        <div class="modal fade" id="noProductosModal" tabindex="-1" role="dialog" aria-labelledby="noProductosModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="noProductosModalLabel">Aviso</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        Debes agregar al menos un producto antes de enviar el pedido.
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal de aviso de mesa -->
        <div class="modal fade" id="noMesaModal" tabindex="-1" role="dialog" aria-labelledby="noMesaModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="noMesaModalLabel">Aviso</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        Debes seleccionar una mesa antes de enviar el pedido.
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        function initializeScrollbar() {
            setTimeout(function () {
                $('#platosContainer').mCustomScrollbar({
                    theme: 'minimal-dark'
                });
            }, 350); // Ajusta el tiempo según sea necesario
        }

        $(document).ready(function () {
            var platos = @Html.Raw(JsonConvert.SerializeObject(ViewBag.Platos));

            // Función para llenar el contenedor con los platos filtrados
            function populatePlatoContainer(filteredPlatos) {
                var container = $('#platosContainer');
                container.empty();

                filteredPlatos.forEach(function (plato) {
                    var imageSrc = plato.ImagenData
                        ? `data:image/jpeg;base64,${plato.ImagenData}`  // Asegúrate de que el tipo MIME sea correcto
                        : 'https://via.placeholder.com/150';  // Placeholder en caso de no tener imagen

                    var platoCard = `
                                            <div class="col-xs-12 col-sm-6 col-md-3">
                                                <div class="card" data-id="${plato.Id}" data-nombre="${plato.Nombre}" data-precio="${plato.Precio}">
                                                    <img src="${imageSrc}" class="card-img-top" alt="${plato.Nombre}">
                                                    <div class="card-body">
                                                        <h5 class="card-title">${plato.Nombre}</h5>
                                                        <p class="card-text">Categoría: ${plato.Categoria}</p>
                                                        <p class="card-text">Precio: ${plato.Precio}</p>
                                                        <button type="button" class="btn btn-primary agregarPlatoBtn">Agregar</button>
                                                    </div>
                                                </div>
                                            </div>
                                        `;
                    container.append(platoCard);
                });
            }

            var platosDisponibles = platos.filter(function (plato) {
                return plato.Disponible;
            });

            // Inicializa el contenedor con todos los platos al cargar la página
            populatePlatoContainer(platosDisponibles);

            // Filtra los platos cuando se escribe en el campo de búsqueda
            $('#searchPlato').on('input', function () {
                var searchTerm = $(this).val().toLowerCase();
                var filteredPlatos = platosDisponibles.filter(function (plato) {
                    return plato.Nombre.toLowerCase().includes(searchTerm);
                });
                $('#platosContainer').mCustomScrollbar('destroy');
                initializeScrollbar();
                populatePlatoContainer(filteredPlatos);
            });

            // Manejar el botón de agregar plato
            $(document).on('click', '.agregarPlatoBtn', function () {
                var platoId = $(this).closest('.card').data('id');
                var platoNombre = $(this).closest('.card').data('nombre');
                var platoPrecio = $(this).closest('.card').data('precio');

                var newRow = `
                                        <tr data-id="${platoId}">
                                            <td>${platoNombre}</td>
                                            <td>
                                                <input type="number" name="PlatosSeleccionados[${platoId}]" value="1" min="1" max="10" class="form-control cantidadPlato" min="1" />
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-danger btn-sm eliminarPlatoBtn">Eliminar</button>
                                            </td>
                                        </tr>
                                    `;

                $('#platosSeleccionados').append(newRow);
                actualizarTotal();
            });

            // Manejar el botón de eliminar plato
            $(document).on('click', '.eliminarPlatoBtn', function () {
                $(this).closest('tr').remove();
                actualizarTotal();
            });

            // Actualizar el total del pedido
            $(document).on('input', '.cantidadPlato', function () {
                actualizarTotal();
            });

            // Función para actualizar el total del pedido
            function actualizarTotal() {
                var total = 0;

                $('#platosSeleccionados tr').each(function () {
                    var platoId = $(this).data('id');
                    var cantidad = $(this).find('.cantidadPlato').val();
                    var plato = platos.find(function (p) { return p.Id == platoId; });
                    total += (plato.Precio) * (cantidad);

                });

                $('#totalPedido').text(total);
                $('#inputTotalPedido').val(total);
            }

            $('.mesa-boton').on('click', function () {
                console.log('Botón de mesa clickeado');

                var mesaId = $(this).data('id');
                var estado = $(this).data('estado');
                console.log('Mesa ID:', mesaId, 'Estado:', estado);

                if (estado === 'DISPONIBLE' || estado === 'Disponible') {
                    $('#IdMesa').val(mesaId);
                    $('.mesa-boton').removeClass('mesa-seleccionada');
                    $(this).addClass('mesa-seleccionada');
                    console.log('Mesa seleccionada:', mesaId);
                }
            });

            $('form').on('submit', function (e) {
                var hayProductos = $('#platosSeleccionados tr').length > 0;
                var mesaSeleccionada = $('#IdMesa').val() !== '';

                if (!hayProductos) {
                    e.preventDefault();
                    $('#noProductosModal').modal('show');
                } else if (!mesaSeleccionada) {
                    e.preventDefault();
                    $('#noMesaModal').modal('show');
                } else {
                    // Agrupar platos por ID y actualizar el formulario
                    var platosAgrupados = {};

                    $('#platosSeleccionados tr').each(function () {
                        var platoId = $(this).data('id');
                        var cantidad = $(this).find('.cantidadPlato').val();

                        if (platosAgrupados[platoId]) {
                            platosAgrupados[platoId] += parseInt(cantidad);
                        } else {
                            platosAgrupados[platoId] = parseInt(cantidad);
                        }
                    });

                    // Limpiar los datos previos del formulario
                    $('input[name^="PlatosSeleccionados"]').remove();

                    // Añadir datos agrupados al formulario
                    for (var id in platosAgrupados) {
                        $('<input>').attr({
                            type: 'hidden',
                            name: `PlatosSeleccionados[${id}]`,
                            value: platosAgrupados[id]
                        }).appendTo('form');
                    }
                }
                
            });
            initializeScrollbar();
        });
    </script>

</body>
</html>
