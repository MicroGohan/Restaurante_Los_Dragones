@model IEnumerable<Dal.Dragones.Pedido>

@{
    ViewBag.Title = "Pedidos en Cocina";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>

        .container-cards {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            justify-content: center;
            padding: 20px;
        }

        .nav-item a {
            text-decoration: none;
            color: inherit;
            display: inline-block;
            cursor: pointer;
            font-size: 27px;
        }

        .card {
            position: relative;
            background-color: #fff;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            width: 18rem;
            margin: 1rem;
            transition: transform 0.2s;
        }

            .card:hover {
                transform: translateY(-10px);
            }

        .card-body {
            padding: 20px;
        }

        .card-title {
            font-size: 18px;
            font-weight: bold;
            margin: 0 0 10px 0;
        }

        .card-text {
            margin: 0 0 10px 0;
            color: #555;
        }

        .btn-primary {
            position: absolute; /* Posiciona el botón en relación con el contenedor .card */
            top: 10px;
            right: 10px;
            /* Asegura que el botón tenga un aspecto apropiado */
            padding: 10px 20px;
            font-size: 14px;
        }

        .btn-actions {
            display: flex;
            justify-content: center;
            gap: 15px; /* Ajusta el espacio entre los botones según tu preferencia */
            margin-top: 20px;
        }

            .btn-actions .btn {
                padding: 7px 12px; /* Aumenta el tamaño del botón */
                font-size: 17px; /* Ajusta el tamaño del texto dentro del botón */
            }

        .modal-content {
            text-align: center;
        }

        .warning-icon {
            font-size: 50px;
            color: #ffcc00; /* Color amarillo para el icono de advertencia */
        }

        #modalDetallesPendientes .modal-dialog {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh; /* Altura mínima para centrar verticalmente */
            margin: 0;
            width: 100%; /* Añadido para asegurar que ocupa todo el ancho */
        }

        #modalDetallesPendientes .modal-dialog-centered {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%; /* Añadido para asegurar que ocupa todo el ancho */
        }

        /* Estilo para el overlay oscuro del modal */
        .modal-backdrop.show {
            opacity: 0.5;
        }



    </style>
</head>
<body>
    <div class="content-page-container full-reset custom-scroll-containers">
        <!-- Navbar -->
        <nav class="navbar-user-top full-reset">
            <ul class="list-unstyled full-reset">
                <figure>
                    <img src="~/assets/img/user01.png" alt="user-picture" class="img-responsive img-circle center-box">
                </figure>
                <li class="user-info" style="color:#fff; cursor:default;">
                    @if (User.Identity.IsAuthenticated)
                    {
                    <li class="user-info">
                        <div class="user-details">
                            <span data-placement="bottom" title="Usuario">Bienvenido, @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value @User.Identity.Name</span>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a href="#" id="logout-button" class="exit-system-button">
                            <i class="zmdi zmdi-power"></i>
                        </a>
                    </li>
                    }
                </li>
                <li class="tooltips-general btn-help" data-placement="bottom" title="Ayuda">
                    <i class="zmdi zmdi-help-outline zmdi-hc-fw"></i>
                </li>
                <li class="mobile-menu-button visible-xs" style="float: left !important;">
                    <i class="zmdi zmdi-menu"></i>
                </li>
                <li class="desktop-menu-button hidden-xs" style="float: left !important;">
                    <i class="zmdi zmdi-swap"></i>
                </li>
            </ul>
        </nav>

        <!-- Contenido principal -->
        <div class="container">
            <div class="page-header">
                <h1 class="all-tittles">Sistema Restaurante Los Dragones <small>Pedidos en Cocina</small></h1>
            </div>
        </div>

        <div class="container-fluid" style="margin: 50px 0;">
            <div class="row">
                <div class="col-xs-12 col-sm-4 col-md-3">
                    <img src="~/assets/img/user01.png" alt="user" class="img-responsive center-box" style="max-width: 110px;">
                </div>
                <div class="col-xs-12 col-sm-8 col-md-8 text-justify lead">
                    En esta sección puedes ver los Pedidos mandados a cocina por el sistema.
                </div>
            </div>
        </div>

        <div class="container-fluid">
            <div class="row">
                <div class="col-xs-12 lead">
                    <ol class="breadcrumb">
                        <li class="active">Pedidos de Cocina</li>
                    </ol>
                </div>
            </div>
        </div>

        <!-- Tarjetas de Pedidos en Cocina -->
        <div class="container-cards" id="pedidos-container">
            @foreach (var pedido in Model)
            {
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Mesa: @pedido.Mesa.NumMesa</h5>
                        <p class="card-text">Fecha: @pedido.Fecha.ToString("M/d/yyyy h:mm:ss tt")</p>
                        <p class="card-text">Total: @pedido.Total</p>
                        <p class="card-text">Detalles:</p>
                        @foreach (var detalle in pedido.Detalles)
                        {
                            <p>
                                @detalle.Nombre - Cantidad: @detalle.Cantidad
                                @if (detalle.ListaComida || detalle.Categoria == "Bebida")
                                {
                                    <span class="text-success">&#x2714;</span> <!-- Check mark -->
                                }
                                else
                                {
                                    <span class="text-danger">&#x26A0;</span> <!-- Warning icon -->
                                }
                                @if (detalle.Categoria == "Comida" && detalle.ListaComida == false)
                                {
                                    <button class="btn btn-success"
                                            onclick="marcarComoEntregado('@pedido.Id', '@detalle.Id')">
                                        Entregado
                                    </button>
                                }
                            </p>
                        }
                        <a asp-action="DetallesCocina" asp-route-id="@pedido.Id" class="btn btn-primary">Ver Orden</a>
                        
                    </div>
                </div>
            }
            
        </div>

        <div class="modal fade" id="modalDetallesPendientes" tabindex="-1" role="dialog" aria-labelledby="modalDetallesPendientesLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modalDetallesPendientesLabel">Detalles Pendientes</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <span class="warning-icon">&#x26A0;</span>
                        <p>No se puede finalizar el pedido porque faltan los siguientes productos que aún no están preparados:</p>
                        <p id="listaDetallesPendientes"></p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Volver</button>
                    </div>
                </div>
            </div>
        </div>
        
    </div>

    


    <script>
        $(document).ready(function () {
            function actualizarPedidos() {
                $.ajax({
                    url: '@Url.Action("ObtenerPedidosCocina")',
                    method: 'GET',
                    success: function (data) {
                        console.log(data); // Para inspeccionar los datos recibidos
                        $('#pedidos-container').empty();

                        data.forEach(function (pedido) {
                            if (pedido.mesa && pedido.mesa.numMesa !== undefined) {
                                const fecha = new Date(pedido.fecha);
                                const opcionesFecha = {
                                    month: 'numeric',
                                    day: 'numeric',
                                    year: 'numeric'
                                };
                                const opcionesHora = {
                                    hour: 'numeric',
                                    minute: 'numeric',
                                    second: 'numeric',
                                    hour12: true
                                };

                                // Formatear la fecha
                                const fechaFormateada = fecha.toLocaleDateString('en-US', opcionesFecha) + ' ' + fecha.toLocaleTimeString('en-US', opcionesHora);

                                // Crear el contenido HTML para los detalles del pedido
                                let detallesHtml = '';
                                pedido.detalles.forEach(function (detalle) {
                                    let estadoIcono = detalle.listaComida || detalle.categoria == "Bebida"
                                        ? '<span class="text-success">&#x2714;</span>' // Check mark
                                        : '<span class="text-danger">&#x26A0;</span>'; // Warning icon

                                    let botonEntregado = '';
                                    if (detalle.categoria == "Comida" && detalle.listaComida == false) {
                                        botonEntregado = `
                                            <button class="btn btn-success"
                                                    onclick="marcarComoEntregado('${pedido.id}', '${detalle.id}')">
                                                Entregado
                                            </button>`;
                                    }

                                    detallesHtml += `
                                        <p>
                                            ${detalle.nombre} - Cantidad: ${detalle.cantidad}
                                            ${estadoIcono}
                                            ${botonEntregado}
                                        </p>`;
                                });

                                $('#pedidos-container').append(
                                    `<div class="card">
                                        <div class="card-body">
                                            <h5 class="card-title">Mesa: ${pedido.mesa.numMesa}</h5>
                                            <p class="card-text">Fecha: ${fechaFormateada}</p>
                                            <p class="card-text">Total: ${pedido.total}</p>
                                            <p class="card-text">Detalles:</p>
                                            ${detallesHtml}
                                            <a href="/Pedido/DetallesCocina/${pedido.id}" class="btn btn-primary">Ver Orden</a>
                                        </div>
                                    </div>`
                                );
                            } else {
                                console.error('Pedido sin Mesa o NumMesa:', pedido);
                            }
                        });
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        console.error('Error al obtener pedidos:', textStatus, errorThrown);
                    }
                });
            }

            setInterval(actualizarPedidos, 2000);

            window.marcarComoEntregado = function (pedidoId, detalleId) {
                $.ajax({
                    url: '/Pedido/CambiarEstadoEntregadoCocina', // Reemplaza con la URL correcta si es diferente
                    method: 'POST',
                    data: {
                        idPedido: pedidoId,
                        detallesSeleccionados: [detalleId] // Enviamos el detalleId en una lista
                    },
                    success: function (response) {
                        console.log('Detalle marcado como entregado:', detalleId);
                        // Actualizar la vista después de marcar como entregado
                        actualizarPedidos();
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        console.error('Error al marcar como entregado:', textStatus, errorThrown);
                    }
                });
            };

            window.verificarDetallesPendientes = function (pedidoId) {
                $.ajax({
                    url: '@Url.Action("ObtenerDetallesPedido")',
                    method: 'GET',
                    data: { idPedido: pedidoId },
                    success: function (response) {
                        if (response.success) {
                            if (response.detallesPendientes.length > 0) {
                                // Mostrar los detalles pendientes en el modal
                                $('#listaDetallesPendientes').empty();
                                response.detallesPendientes.forEach(function (detalle) {
                                    $('#listaDetallesPendientes').append('<li>' + detalle.nombre + ' - Cantidad: ' + detalle.cantidad + '</li>');
                                });
                                $('#modalDetallesPendientes').modal('show');
                            } else {
                                // Si no hay detalles pendientes, finalizar el pedido
                                finalizarPedido(pedidoId);
                            }
                        } else {
                            console.error('Error al obtener detalles del pedido:', response.message);
                        }
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        console.error('Error al obtener detalles del pedido:', textStatus, errorThrown);
                    }
                });
            };

            window.finalizarPedido = function (pedidoId) {
                $.ajax({
                    url: '/Pedido/FinalizarPedido02',
                    method: 'POST',
                    data: {
                        idPedido: pedidoId
                    },
                    success: function (response) {
                        if (response.success) {
                            console.log('Pedido finalizado:', pedidoId);
                            // Actualizar la vista después de finalizar el pedido
                            actualizarPedidos();
                        } else {
                            console.error('Error al finalizar el pedido:', response.message);
                        }
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        console.error('Error al finalizar el pedido:', textStatus, errorThrown);
                    }
                });
            };

            window.closeErrorModal = function () {
                $('#errorModal').hide();
            };

        });

    </script>
</body>
</html>
