@model Tuple<DateTime?, DateTime?>
@using Dal.Dragones
@using System.Security.Claims
@{
    ViewData["Title"] = "Total Facturado por Fecha Seleccionada";
    var facturas = ViewBag.Facturas as List<Factura>;
    var fechaInicio = ViewBag.FechaInicio != null ? ((DateTime)ViewBag.FechaInicio).ToString("yyyy-MM-dd") : string.Empty;
    var fechaFin = ViewBag.FechaFin != null ? ((DateTime)ViewBag.FechaFin).ToString("yyyy-MM-dd") : string.Empty;
}
<head>
    <style>
        .nav-item a {
            text-decoration: none; /* Quitar subrayado */
            color: inherit; /* Heredar el color del texto */
            display: inline-block; /* Hacerlo un bloque en línea para aplicar padding correctamente */
            cursor: pointer; /* Cambiar el cursor a puntero */
            font-size: 27px;
        }

        .content-page {
            max-width: 900px; /* Ancho máximo del contenido */
            margin: 0 auto; /* Centrar horizontalmente */
            padding: 20px; /* Padding interno */
            background-color: #fff; /* Fondo blanco para el contenido */
            border-radius: 8px; /* Bordes redondeados */
            display: flex; /* Usar flexbox para centrar contenido */
            flex-direction: column; /* Colocar los elementos en una columna */
            align-items: center; /* Centrar los elementos horizontalmente */
            justify-content: center; /* Centrar los elementos verticalmente */
        }

        .btn{
        margin-bottom: 5px;
        }
    </style>
</head>
<div class="content-page-container full-reset custom-scroll-containers">
    <nav class="navbar-user-top full-reset">
        <ul class="list-unstyled full-reset">
            <figure>
                <img src="~/assets/img/user01.png" alt="user-picture" class="img-responsive img-circle center-box">
            </figure>
            <li class="user-info" style="color:#fff; cursor:default;">
                @if (User.Identity.IsAuthenticated)
                {
                <li class="user-info">
                    <div class="user-details">
                        <span data-placement="bottom" title="Usuario">Bienvenido, @User.FindFirst(ClaimTypes.Role)?.Value @User.Identity.Name</span>
                    </div>
                </li>
                <li class="nav-item">
                    <a href="#" id="logout-button" class="exit-system-button">
                        <i class="zmdi zmdi-power"></i>
                    </a>
                </li>
                }
            </li>
            <li class="tooltips-general btn-help" data-placement="bottom" title="Ayuda">
                <i class="zmdi zmdi-help-outline zmdi-hc-fw"></i>
            </li>
            <li class="mobile-menu-button visible-xs" style="float: left !important;">
                <i class="zmdi zmdi-menu"></i>
            </li>
            <li class="desktop-menu-button hidden-xs" style="float: left !important;">
                <i class="zmdi zmdi-swap"></i>
            </li>
        </ul>
    </nav>
    <div class="content-page">
        <h2>@ViewData["Title"]</h2>

        <form asp-action="TotalFacturadoPorFechaSeleccionada" method="post">
            <div class="form-group">
                <label for="fechaInicio">Fecha de Inicio:</label> <br />
                <input type="date" id="fechaInicio" name="fechaInicio" max="@DateTime.Now.ToString("yyyy-MM-dd")" value="@fechaInicio" required />
            </div>
            <div class="form-group">
                <label for="fechaFin">Fecha de Finalizacion:</label> <br />
                <input type="date" id="fechaFin" name="fechaFin" max="@DateTime.Now.ToString("yyyy-MM-dd")" value="@fechaFin" required />
            </div>
            <div style ="text-align: center;">
                <button type="submit" class="btn btn-primary">Obtener Total</button>
            </div>
        </form>

        @if (!ViewData.ModelState.IsValid)
        {

            <div class="validation-summary-errors">
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        @if (ViewBag.TotalFacturado != null)
        {
            <p>Total Facturado: @ViewBag.TotalFacturado</p>
            <form asp-action="DownloadPDFPorFechaSeleccionada" method="post">
                <input type="hidden" id="fechaInicioHidden" name="fechaInicio" value="@fechaInicio" required />
                <input type="hidden" id="fechaFinHidden" name="fechaFin" value="@fechaFin" required />
                <button type="submit" class="btn btn-primary">Descargar PDF</button>
            </form>
        }

        @if (facturas != null && facturas.Any())
        {
            <h3>Facturas del Período</h3>
            <button id="export-btn" class="btn btn-success">Exportar a Excel</button>
            <table class="table table-secondary table-bordered table-hover" id="tabla">
                <thead class="thead-dark">
                    <tr>
                        <th>Fecha</th>
                        <th>Nombre Cliente</th>
                        <th>Subtotal</th>
                        <th>IVA</th>
                        <th>Total a Pagar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var factura in facturas)
                    {
                        <tr>
                            <td>@factura.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@factura.NombreCliente</td>
                            <td>@factura.Subtotal</td>
                            <td>%@factura.Iva</td>
                            <td>@factura.TotalPagar</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        <a class="btn btn-primary" href="@Url.Action("Index", "Reporte")">Volver a Reportes</a>
    </div>
</div>
<script>
    function updateHiddenFechaInicio() {
        var fechaInicioDisplay = document.getElementById('fechaInicio').value;
        document.getElementById('fechaInicioHidden').value = fechaInicioDisplay;
    }
    function updateHiddenFechaFin() {
        var fechaFinDisplay = document.getElementById('fechaFin').value;
        document.getElementById('fechaFinHidden').value = fechaFinDisplay;
    }
</script>
<script>
    $(document).ready(function () {
        $('#tabla').DataTable({
            language: {
                processing: "Procesando...",
                search: "Buscar:",
                lengthMenu: "Mostrar _MENU_ elementos",
                info: "Mostrando del _START_ al _END_ de un total de _TOTAL_ elementos",
                infoEmpty: "Mostrando 0 elementos",
                infoFiltered: "(filtrado de un total de _MAX_ elementos)",
                infoPostFix: "",
                loadingRecords: "Cargando...",
                zeroRecords: "No se encontraron registros coincidentes",
                emptyTable: "No hay datos disponibles en la tabla",
                paginate: {
                    first: "Primero",
                    previous: "Anterior",
                    next: "Siguiente",
                    last: "Último"
                },
                aria: {
                    sortAscending: ": activar para ordenar la columna de manera ascendente",
                    sortDescending: ": activar para ordenar la columna de manera descendente"
                }
            }
        });
    });
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.0/xlsx.full.min.js"></script>

<script>
    document.getElementById('export-btn').addEventListener('click', function () {
        // Obtén la tabla
        var wb = XLSX.utils.table_to_book(document.getElementById('tabla'), { sheet: "Sheet1" });

        // Crea un archivo Excel
        XLSX.writeFile(wb, 'Datos.xlsx');
    });
</script>


